{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "Represents a shop registered on the platform.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "shopName": { "type": "string" },
        "ownerName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "basic", "premium"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerUid": { "type": "string" },
        "slug": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["shopName", "ownerName", "email", "ownerUid", "slug"]
    },
    "Product": {
      "title": "Product",
      "description": "A product sold by a shop.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "name", "price", "quantity"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of a completed sale.",
      "type": "object",
      "properties": {
        "saleId": { "type": "string" },
        "shopId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "customerPhone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "items", "total"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of a shop.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "purchaseHistory": { "type": "array" },
        "loyaltyPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "phone"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed through the online mini store.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "shopId": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerName": { "type": "string" },
        "products": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed"] },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "customerPhone", "products", "status"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Collection of shops."
    },
    "/shops/{shopId}/products/{productId}": {
      "schema": "Product",
      "description": "Products belonging to a specific shop."
    },
    "/shops/{shopId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records for a specific shop."
    },
    "/shops/{shopId}/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customers of a specific shop."
    },
    "/shops/{shopId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Online orders for a specific shop."
    }
  }
}
