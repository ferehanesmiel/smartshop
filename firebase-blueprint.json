{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "shop_owner", "admin"] },
        "name": { "type": "string" },
        "wallet_id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Shop owner's store information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "place_id": { "type": "string" },
        "location": { "type": "object" },
        "contact": { "type": "object" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "verified_status": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["basic", "pro", "premium", "featured"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "plan"]
    },
    "Product": {
      "title": "Product",
      "description": "Product listed in a shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "object" },
        "description": { "type": "object" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "stock": { "type": "integer" },
        "vatInclusive": { "type": "boolean" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "barcode": { "type": "string" },
        "qrCode": { "type": "string" },
        "isPublishedToMarketplace": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shopId", "name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order for products from a shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "shop_id": { "type": "string" },
        "products": { "type": "array", "items": { "type": "object" } },
        "total_price": { "type": "number" },
        "payment_method": { "type": "string", "enum": ["SBR", "cash", "mobile_money"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "preparing", "ready", "delivered", "cancelled"] },
        "delivery_id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "shop_id", "products", "total_price"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User's digital wallet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "balance_sbr": { "type": "number" },
        "balance_birr": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "balance_sbr", "balance_birr"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Shop's promotion subscription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shop_id": { "type": "string" },
        "plan": { "type": "string", "enum": ["basic", "pro", "premium", "featured"] },
        "cost_sbr": { "type": "number" },
        "duration_days": { "type": "number" },
        "active_status": { "type": "boolean" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shop_id", "plan", "cost_sbr"]
    },
    "Rating": {
      "title": "Rating",
      "description": "Review and rating for shop or product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "shop_id": { "type": "string" },
        "product_id": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "rating"]
    },
    "Delivery": {
      "title": "Delivery",
      "description": "Runner Link delivery request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order_id": { "type": "string" },
        "runner_id": { "type": "string" },
        "pickup": { "type": "object" },
        "dropoff": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "assigned", "picked_up", "delivered"] },
        "live_location": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "order_id", "pickup", "dropoff", "status"]
    },
    "Place": {
      "title": "Place",
      "description": "City place added by scouts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "object" },
        "addedBy": { "type": "string" },
        "verified": { "type": "boolean" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "category", "location", "addedBy"]
    },
    "Task": {
      "title": "Task",
      "description": "Scout task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "reward_sbr": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "reward_sbr", "status"]
    },
    "TaskSubmission": {
      "title": "TaskSubmission",
      "description": "Submission for a scout task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "data": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "taskId", "userId", "status"]
    },
    "Donation": {
      "title": "Donation",
      "description": "Blooming Heart donation campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "goal_birr": { "type": "number" },
        "raised_birr": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "goal_birr", "raised_birr", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/shops/{shopId}": { "schema": "Shop", "description": "Store information" },
    "/products/{productId}": { "schema": "Product", "description": "Products in the marketplace" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/wallets/{walletId}": { "schema": "Wallet", "description": "User wallets" },
    "/subscriptions/{subId}": { "schema": "Subscription", "description": "Shop subscriptions" },
    "/ratings/{ratingId}": { "schema": "Rating", "description": "Reviews and ratings" },
    "/deliveries/{deliveryId}": { "schema": "Delivery", "description": "Delivery tracking" },
    "/places/{placeId}": { "schema": "Place", "description": "City places" },
    "/tasks/{taskId}": { "schema": "Task", "description": "Scout tasks" },
    "/submissions/{subId}": { "schema": "TaskSubmission", "description": "Task submissions" },
    "/donations/{donationId}": { "schema": "Donation", "description": "Donation campaigns" },
    "/notifications/{notifId}": { "schema": "Notification", "description": "User notifications" }
  }
}
