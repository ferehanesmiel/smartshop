{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "shop_owner", "admin"] },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Shop owner's store information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "subscriptionPlan": { "type": "string", "enum": ["Basic", "Pro", "Premium"] },
        "logoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "subscriptionPlan"]
    },
    "Product": {
      "title": "Product",
      "description": "Product listed in a shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "object", "description": "Multi-language name {en: string, am: string}" },
        "description": { "type": "object", "description": "Multi-language description {en: string, am: string}" },
        "price": { "type": "number" },
        "costPrice": { "type": "number" },
        "stock": { "type": "integer" },
        "vatInclusive": { "type": "boolean" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "barcode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shopId", "name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order for products from a shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "shopId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "vatAmount": { "type": "number" },
        "commissionAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["Cash on Delivery", "Telebirr", "Bank Transfer"] },
        "paymentStatus": { "type": "string", "enum": ["Pending", "Paid", "Failed"] },
        "orderStatus": { "type": "string", "enum": ["Pending", "Confirmed", "Shipped", "Delivered", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerId", "shopId", "items", "totalAmount"]
    },
    "Sale": {
      "title": "Sale",
      "description": "POS transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalPrice": { "type": "number" },
        "vat": { "type": "number" },
        "profit": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "Telebirr", "Bank Transfer"] },
        "saleDate": { "type": "string", "format": "date-time" },
        "cashierId": { "type": "string" }
      },
      "required": ["id", "shopId", "items", "totalPrice", "profit", "paymentMethod", "saleDate"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/shops/{shopId}": { "schema": "Shop", "description": "Store information" },
    "/products/{productId}": { "schema": "Product", "description": "Products in the marketplace" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/sales/{saleId}": { "schema": "Sale", "description": "POS sales transactions" }
  }
}
