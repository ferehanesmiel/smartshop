// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: shops
// Document ID: shopId
// Fields:
//   - shopId: string (required)
//   - shopName: string (required)
//   - ownerName: string (required)
//   - phone: string (required)
//   - email: string (required)
//   - plan: string (required)
//   - createdAt: string (required)
//   - ownerUid: string (required)
//   - slug: string (required)
//   - status: string (required)
//
// Collection: products
// Document ID: productId
// Fields:
//   - shopId: string (required)
//   - quantity: number (required)
//
// Collection: sales
// Document ID: saleId
// Fields:
//   - shopId: string (required)
//   - totalAmount: number (required)
//   - createdAt: string (required)
//   - paymentMethod: string (required)
//
// Collection: customers
// Document ID: customerId
// Fields:
//   - shopId: string (required)
//
// Collection: orders
// Document ID: orderId
// Fields:
//   - shopId: string (required)
//   - status: string (required)
//
// Collection: receipts
// Document ID: receiptId
// Fields:
//   - shopId: string (required)
//
// Collection: staff
// Document ID: staffId
// Fields:
//   - shopId: string (required)
//   - name: string (required)
//   - email: string (required)
//   - role: string (required)
//
// Collection: branches
// Document ID: branchId
// Fields:
//   - shopId: string (required)
//   - name: string (required)
//
// Collection: subscriptions
// Document ID: subscriptionId
// Fields:
//   - shopId: string (required)
//   - planName: string (required)
//   - subscriptionStatus: string (required)
//
// Collection: admins
// Document ID: adminId
// Fields:
//   - (none explicitly defined)
//
// Collection: siteSettings
// Document ID: (any)
// Fields:
//   - (none explicitly defined)
//
// ===============================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isShopOwner(shopId) {
      return isAuthenticated() && (
        isAdmin() || (shopId != null && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == request.auth.uid)
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "esmielferehan@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isShopOwner(shopId);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isShopOwner(resource.data.shopId);
    }

    match /sales/{saleId} {
      allow read: if isAdmin() || isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAdmin() || isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isShopOwner(resource.data.shopId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isShopOwner(resource.data.shopId);
      allow create: if true; // Public can place orders
      allow update: if isAdmin() || isShopOwner(resource.data.shopId);
      allow delete: if isAdmin() || isShopOwner(resource.data.shopId);
    }

    match /receipts/{receiptId} {
      allow read: if isAdmin() || isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isAdmin() || isShopOwner(resource.data.shopId);
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isAdmin() || isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isShopOwner(resource.data.shopId);
    }

    match /branches/{branchId} {
      allow read: if isAdmin() || isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isShopOwner(resource.data.shopId);
    }

    match /subscriptions/{subscriptionId} {
      allow get: if isShopOwner(resource.data.shopId) || isAdmin();
      allow list: if isAdmin() || isAuthenticated();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    match /siteSettings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
