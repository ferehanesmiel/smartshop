rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isShopOwner(shopId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == request.auth.uid ||
        isAdmin()
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "esmielferehan@gmail.com" && request.auth.token.email_verified == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isShopOwner(shopId);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isShopOwner(resource.data.shopId);
    }

    match /sales/{saleId} {
      allow read: if isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId) && 
                      (request.resource.data.shopId == resource.data.shopId);
      allow delete: if isShopOwner(resource.data.shopId);
    }

    match /orders/{orderId} {
      allow read: if isShopOwner(resource.data.shopId);
      allow create: if true; // Public can place orders
      allow update: if isShopOwner(resource.data.shopId);
      allow delete: if isShopOwner(resource.data.shopId);
    }

    match /receipts/{receiptId} {
      allow read: if isShopOwner(resource.data.shopId);
      allow create: if isShopOwner(request.resource.data.shopId);
      allow update: if isShopOwner(resource.data.shopId);
      allow delete: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isShopOwner(resource.data.shopId) || isAdmin();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
