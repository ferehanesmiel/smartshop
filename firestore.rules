rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(shopId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == request.auth.uid ||
        (request.auth.token.email == "esmielferehan@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "esmielferehan@gmail.com" && request.auth.token.email_verified == true
      );
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Shop: { shopName: string, ownerName: string, email: string, ownerUid: string, slug: string, status: string }
    // Product: { name: string, price: number, quantity: number, shopId: string }
    // Sale: { items: list, total: number, shopId: string }
    // Order: { customerPhone: string, products: list, status: string, shopId: string }

    match /shops/{shopId} {
      allow read: if true; // Public for mini stores
      allow create: if isAuthenticated() && 
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.status == 'active';
      allow update: if isOwner(shopId) || isAdmin();
      allow delete: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isOwner(shopId);
      }

      match /sales/{saleId} {
        allow read, write: if isOwner(shopId);
      }

      match /customers/{customerId} {
        allow read, write: if isOwner(shopId);
      }

      match /orders/{orderId} {
        allow read: if isOwner(shopId);
        allow create: if true; // Customers placing orders
        allow update: if isOwner(shopId);
        allow delete: if isOwner(shopId);
      }
    }
  }
}
